---
const glyphs = [
  { ch: '¶', top: '8%',  left: '4%',  size: '7rem',  dur: '52s', delay: '0s'   },
  { ch: '§', top: '62%', left: '12%', size: '5rem',  dur: '64s', delay: '-18s' },
  { ch: '❧', top: '24%', left: '38%', size: '9rem',  dur: '74s', delay: '-40s' },
  { ch: '&', top: '74%', left: '46%', size: '6rem',  dur: '58s', delay: '-9s'  },
  { ch: 'ﬁ', top: '12%', left: '72%', size: '8rem',  dur: '68s', delay: '-30s' },
  { ch: '✻', top: '55%', left: '85%', size: '4.5rem',dur: '47s', delay: '-22s' },
  { ch: '„', top: '40%', left: '60%', size: '10rem', dur: '80s', delay: '-55s' },
];
---
<section class="hero" id="inicio">
  <!-- Animação de fundo: glifos editoriais à deriva -->
  <div class="hero-bg" aria-hidden="true">
    {glyphs.map(g => (
      <span
        class="glyph"
        style={`top:${g.top}; left:${g.left}; font-size:${g.size}; animation-duration:${g.dur}; animation-delay:${g.delay};`}
      >{g.ch}</span>
    ))}
  </div>

  <div class="container hero-inner">
    <div class="hero-text">
      <p class="meta hero-kicker">Casa editorial para quem escreve sério</p>

      <h1>
        Do manuscrito<br />
        ao livro<br />
        <span class="hero-tone">publicado.</span>
      </h1>

      <p class="prose hero-sub">
        Design editorial, ISBN, DOI e distribuição em mais de 40 plataformas
        globais, tudo em um único parceiro editorial.
      </p>

      <div class="hero-actions">
        <a
          href="https://wa.me/5581999999999?text=Olá%2C%20quero%20publicar%20meu%20livro%20com%20a%20Filos!"
          class="btn-fill"
          target="_blank"
          rel="noopener"
        >
          Publicar meu livro
          <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
        </a>
        <a href="#servicos" class="link-line">Ver serviços</a>
      </div>

      <p class="meta hero-foot">
        +40 plataformas globais &middot; ISBN &amp; DOI garantidos &middot; 98% de satisfação
      </p>
    </div>

    <div class="hero-visual">
      <img
        src="/images/hero-photo.webp"
        alt="Autor segurando livro publicado pela Filos Editora"
        class="hero-photo"
        width="560"
        height="680"
        loading="eager"
        decoding="async"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - 74px);
    display: flex;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }

  /* ── fundo animado ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .glyph {
    position: absolute;
    font-family: Georgia, 'Times New Roman', serif;
    color: var(--ink-5);
    opacity: 0.32;
    line-height: 1;
    will-change: transform;
    animation-name: drift;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-direction: alternate;
  }

  @keyframes drift {
    0%   { transform: translate(0, 0) rotate(-4deg); }
    50%  { transform: translate(2.6vw, -3.5vh) rotate(3deg); }
    100% { transform: translate(-1.8vw, 3vh) rotate(-2deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .glyph { animation: none; }
  }

  /* ── grade ── */
  .hero-inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: end;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .hero-text {
    align-self: center;
    padding: var(--sp-6) var(--sp-5) var(--sp-6) 0;
  }

  .hero-kicker { margin-bottom: var(--sp-3); }

  .hero-text h1 {
    margin-bottom: var(--sp-4);
    font-size: clamp(2.6rem, 5.5vw, 4.7rem);
  }

  .hero-tone { color: var(--tone); }

  .hero-sub {
    max-width: 46ch;
    margin-bottom: var(--sp-4);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    flex-wrap: wrap;
    margin-bottom: var(--sp-5);
  }

  .hero-foot {
    padding-top: var(--sp-2);
    border-top: 1px solid var(--line);
    max-width: 46ch;
  }

  /* ── foto: assentada na base da seção ── */
  .hero-visual {
    align-self: end;
    min-width: 0;
    display: flex;
    align-items: flex-end;
    height: 100%;
  }

  .hero-photo {
    width: 100%;
    height: auto;
    max-height: 86vh;
    object-fit: contain;
    object-position: bottom center;
    margin-top: auto;
    filter: drop-shadow(0 28px 56px rgba(8,5,1,.7));
    mask-image:
      linear-gradient(to bottom, transparent 0%, black 14%),
      linear-gradient(to right, transparent 0%, black 12%, black 88%, transparent 100%);
    mask-composite: intersect;
    -webkit-mask-image:
      linear-gradient(to bottom, transparent 0%, black 14%),
      linear-gradient(to right, transparent 0%, black 12%, black 88%, transparent 100%);
    -webkit-mask-composite: source-in;
  }

  /* ── responsivo ── */
  @media (max-width: 900px) {
    .hero { min-height: unset; }

    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-text {
      order: 1;
      padding: var(--sp-5) 0 var(--sp-4);
    }

    .hero-visual {
      order: 2;
      height: auto;
      justify-content: center;
    }

    .hero-photo { max-height: 64vh; }
  }

  @media (max-width: 480px) {
    .hero-actions { align-items: flex-start; flex-direction: column; gap: var(--sp-3); }
  }
</style>
