---
---
<section class="hero-section" id="inicio">
  <div class="container hero-inner">
    <div class="hero-text animate-on-scroll">
      <span class="section-eyebrow">Editora especializada em autores brasileiros</span>

      <h1>
        DO MANUSCRITO<br />
        AO LIVRO<br />
        <span class="highlight">PUBLICADO</span>
      </h1>

      <p class="hero-subtitle">
        Seu manuscrito transformado em obra global.<br />
        Sem barreiras, sem burocracia.
      </p>

      <div class="hero-actions">
        <a
          href="https://wa.me/5581999999999?text=Olá%2C%20quero%20publicar%20meu%20livro%20com%20a%20Filos!"
          class="btn-primary"
          target="_blank"
          rel="noopener"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013 12.6a19.79 19.79 0 01-3.07-8.67A2 2 0 011.9 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Publicar meu livro
        </a>
        <a href="#servicos" class="btn-ghost">
          Ver serviços
          <span class="btn-icon"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></span>
        </a>
      </div>

      <div class="hero-proof">
        <div class="proof-badge">
          <span class="proof-icon">📚</span>
          <span class="proof-text"><strong>+40</strong> plataformas globais</span>
        </div>
        <div class="proof-badge">
          <span class="proof-icon">🏆</span>
          <span class="proof-text"><strong>98%</strong> de satisfação</span>
        </div>
        <div class="proof-badge">
          <span class="proof-icon">🌍</span>
          <span class="proof-text"><strong>DOI</strong> Internacional</span>
        </div>
      </div>

      <a href="#servicos" class="scroll-hint" aria-label="Como funciona">
        Como funciona
        <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </a>
    </div>

    <div class="hero-visual animate-on-scroll" style="transition-delay:.15s">
      <div class="hero-image-wrap">
        <img
          src="/images/hero-photo.webp"
          alt="Autor segurando livro publicado pela Filos Editora"
          class="hero-photo"
          width="560"
          height="680"
          loading="eager"
          decoding="async"
        />
        <div class="hero-image-glow" aria-hidden="true"></div>
      </div>

      <div class="hero-card hero-card-1">
        <span class="hcard-num">+40</span>
        <span class="hcard-label">plataformas globais</span>
      </div>

      <div class="hero-card hero-card-2">
        <span class="hcard-num">98%</span>
        <span class="hcard-label">satisfação dos autores</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: 95vh;
    display: flex;
    align-items: center;
    padding: 80px 0 0;
    overflow: hidden;
    position: relative;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 55% 65% at 70% 50%, rgba(200,169,110,.06) 0%, transparent 65%),
      radial-gradient(ellipse 40% 70% at 5% 60%,  rgba(122,174,232,.03) 0%, transparent 55%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 48px;
    min-height: calc(95vh - 80px);
    position: relative;
    z-index: 1;
  }

  /* ── Text column ── */
  .hero-text { padding-bottom: 60px; }

  .hero-text h1 {
    margin: 0 0 1.25rem;
    line-height: 0.95;
  }

  .hero-subtitle {
    font-family: var(--f-body);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--text2);
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  /* Social proof badges */
  .hero-proof {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .proof-badge {
    display: flex;
    align-items: center;
    gap: 7px;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    padding: 6px 14px 6px 10px;
    box-shadow: var(--sh-sm);
  }

  .proof-icon { font-size: 0.9rem; line-height: 1; }

  .proof-text {
    font-family: var(--f-titles);
    font-size: 0.78rem;
    color: var(--text2);
  }

  .proof-text strong {
    color: var(--gold);
    font-weight: 700;
  }

  /* Scroll hint */
  .scroll-hint {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--f-titles);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text3);
    transition: color var(--dur);
  }

  .scroll-hint:hover { color: var(--gold); }

  .scroll-hint svg {
    width: 16px; height: 16px;
    fill: none; stroke: currentColor; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(4px); }
  }

  /* ── Visual column ── */
  .hero-visual {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    height: 100%;
    min-height: 500px;
  }

  .hero-image-wrap {
    position: relative;
    width: 100%;
    max-width: 480px;
    align-self: flex-end;
  }

  .hero-photo {
    width: 100%;
    height: auto;
    object-fit: contain;
    object-position: bottom center;
    filter: drop-shadow(0 30px 60px rgba(0,0,0,.5));
    position: relative;
    z-index: 2;
    mask-image: linear-gradient(to bottom, transparent 0%, black 12%, black 85%, transparent 100%),
                linear-gradient(to left, transparent 0%, black 15%, black 100%);
    mask-composite: intersect;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 12%, black 85%, transparent 100%),
                        linear-gradient(to left, transparent 0%, black 15%, black 100%);
    -webkit-mask-composite: destination-in;
  }

  [data-theme="light"] .hero-photo {
    filter: drop-shadow(0 20px 40px rgba(80,50,20,.22));
  }

  .hero-image-glow {
    position: absolute;
    bottom: -20px;
    left: 10%;
    right: 10%;
    height: 60px;
    background: radial-gradient(ellipse, var(--gold-bg) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
  }

  /* Floating stat cards */
  .hero-card {
    position: absolute;
    background: var(--bg3);
    border: 1px solid var(--border2);
    border-radius: var(--r-lg);
    padding: 12px 18px;
    box-shadow: var(--sh-md);
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 2px;
    backdrop-filter: blur(8px);
  }

  .hcard-num {
    font-family: var(--f-titles);
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--gold);
    line-height: 1;
  }

  .hcard-label {
    font-family: var(--f-titles);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .hero-card-1 {
    top: 20%;
    left: -20px;
    animation: float1 6s ease-in-out infinite;
  }

  .hero-card-2 {
    bottom: 25%;
    right: -10px;
    animation: float2 7s ease-in-out infinite;
  }

  @keyframes float1 {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-8px); }
  }

  @keyframes float2 {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(6px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-card { animation: none; }
    .scroll-hint svg { animation: none; }
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      min-height: unset;
      padding-top: 20px;
      padding-bottom: 40px;
      gap: 40px;
    }

    .hero-text { padding-bottom: 0; }

    .hero-visual {
      min-height: 360px;
      order: -1;
    }

    .hero-image-wrap { max-width: 320px; }
    .hero-card-1 { left: 0; }
    .hero-card-2 { right: 0; }
  }

  @media (max-width: 480px) {
    .hero-section { min-height: unset; padding: 60px 0 0; }
    .hero-text h1 { font-size: clamp(2.4rem, 9vw, 3.2rem); }
    .hero-visual { min-height: 280px; }
    .hero-image-wrap { max-width: 260px; }
    .hero-actions { flex-direction: column; }
    .hero-card { padding: 10px 14px; }
    .hcard-num { font-size: 1.3rem; }
  }
</style>
