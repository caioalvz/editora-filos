---
const glyphs = [
  { ch: '¶', top: '8%',  left: '4%',  size: '7rem',  dur: '52s', delay: '0s'   },
  { ch: '§', top: '62%', left: '12%', size: '5rem',  dur: '64s', delay: '-18s' },
  { ch: '❧', top: '24%', left: '38%', size: '9rem',  dur: '74s', delay: '-40s' },
  { ch: '&', top: '74%', left: '46%', size: '6rem',  dur: '58s', delay: '-9s'  },
  { ch: 'ﬁ', top: '12%', left: '72%', size: '8rem',  dur: '68s', delay: '-30s' },
  { ch: '✻', top: '55%', left: '85%', size: '4.5rem',dur: '47s', delay: '-22s' },
  { ch: '„', top: '40%', left: '60%', size: '10rem', dur: '80s', delay: '-55s' },
];
---
<section class="hero" id="inicio">
  <!-- Animação de fundo: glifos editoriais à deriva -->
  <div class="hero-bg" aria-hidden="true">
    {glyphs.map(g => (
      <span
        class="glyph"
        style={`top:${g.top}; left:${g.left}; font-size:${g.size}; animation-duration:${g.dur}; animation-delay:${g.delay};`}
      >{g.ch}</span>
    ))}
  </div>

  <div class="container hero-inner">
    <div class="hero-text">
      <p class="meta hero-kicker">Casa editorial para quem escreve sério</p>

      <h1>
        Do manuscrito<br />
        ao livro<br />
        <span class="hero-tone">publicado.</span>
      </h1>

      <p class="prose hero-sub">
        Design editorial, ISBN, DOI e distribuição em mais de 40 plataformas
        globais, tudo em um único parceiro editorial.
      </p>

      <div class="hero-actions">
        <a
          href="https://wa.me/5581999999999?text=Olá%2C%20quero%20publicar%20meu%20livro%20com%20a%20Filos!"
          class="btn-fill"
          target="_blank"
          rel="noopener"
        >
          Publicar meu livro
          <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
        </a>
        <a href="#servicos" class="link-line">Ver serviços</a>
      </div>

      <div class="hero-badges" aria-label="Diferenciais Filos Editora">
        <div class="hero-badge">
          <span class="badge-num">+40</span>
          <span class="badge-label">plataformas globais</span>
        </div>
        <div class="hero-badge">
          <span class="badge-num">100%</span>
          <span class="badge-label">ISBN &amp; DOI garantidos</span>
        </div>
        <div class="hero-badge">
          <span class="badge-num">98%</span>
          <span class="badge-label">autores satisfeitos</span>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-frame">
        <img
          src="/images/hero-photo.webp"
          alt="Autor segurando livro publicado pela Filos Editora"
          class="hero-photo"
          width="560"
          height="680"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    overflow: hidden;
    background: #111111;
    border-bottom: none;
    margin-top: -74px;
    padding-top: 74px;
  }

  /* ── fundo animado ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .glyph {
    position: absolute;
    font-family: 'Spectral', Georgia, 'Times New Roman', serif;
    color: #fff;
    opacity: 0.05;
    line-height: 1;
    will-change: transform;
    animation-name: drift;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-direction: alternate;
  }

  @keyframes drift {
    0%   { transform: translate(0, 0) rotate(-4deg); }
    50%  { transform: translate(2.6vw, -3.5vh) rotate(3deg); }
    100% { transform: translate(-1.8vw, 3vh) rotate(-2deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .glyph { animation: none; }
  }

  /* ── grade ── */
  .hero-inner {
    display: grid;
    grid-template-columns: 1.16fr 0.84fr;
    align-items: end;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .hero-text {
    align-self: center;
    padding: var(--sp-4) var(--sp-5) var(--sp-4) 0;
  }

  .hero-kicker {
    margin-bottom: var(--sp-3);
    color: rgba(255,255,255,0.5);
  }

  .hero-text h1 {
    margin-bottom: var(--sp-4);
    font-size: clamp(2.6rem, 5vw, 4.8rem);
    color: #fff;
  }

  .hero-tone {
    color: var(--amber);
    font-style: italic;
  }

  .hero-sub {
    max-width: 46ch;
    margin-bottom: var(--sp-4);
    color: rgba(255,255,255,0.72);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    flex-wrap: wrap;
    margin-bottom: var(--sp-5);
  }

  /* botão branco sobre navy */
  .hero-text .btn-fill {
    background: #fff;
    color: var(--navy);
  }
  .hero-text .btn-fill:hover {
    background: rgba(255,255,255,0.88);
    transform: translateY(-1px);
  }

  /* link branco sobre navy */
  .hero-text .link-line {
    color: rgba(255,255,255,0.8);
    border-bottom-color: rgba(255,255,255,0.3);
  }
  .hero-text .link-line:hover {
    color: #fff;
    border-bottom-color: rgba(255,255,255,0.7);
  }

  .hero-badges {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    padding-top: var(--sp-3);
    border-top: 1px solid rgba(255,255,255,0.12);
  }

  .hero-badge {
    display: flex;
    flex-direction: column;
    gap: 3px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 4px;
    padding: 10px 16px;
    min-width: 90px;
  }

  .badge-num {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1;
    color: var(--amber);
    letter-spacing: -0.01em;
  }

  .badge-label {
    font-family: var(--f-display);
    font-size: 0.72rem;
    font-weight: 400;
    color: rgba(255,255,255,0.45);
    line-height: 1.3;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ── foto: assentada na base da seção ── */
  .hero-visual {
    align-self: end;
    min-width: 0;
  }

  /* Moldura na proporção da área opaca da imagem (368×502):
     corta só o fundo transparente; o retrato fica mais alto que largo.
     margin-top = 25% da altura da moldura (502/368 da largura),
     mantendo o hero em 1.25× a altura da foto. */
  .hero-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 368 / 502;
    overflow: hidden;
    margin-top: calc(25% * 502 / 368);
    mask-image: linear-gradient(to bottom, transparent 0%, black 12%, black 80%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 12%, black 80%, transparent 100%);
  }

  .hero-photo {
    position: absolute;
    width: calc(100% * 600 / 368);
    max-width: none;
    height: auto;
    left: calc(-100% * 127 / 368);
    top: calc(-100% * 97 / 502);
    filter: drop-shadow(0 28px 56px rgba(0,0,0,.55));
  }

  /* ── responsivo ── */
  @media (max-width: 900px) {
    .hero { min-height: unset; }

    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-text {
      order: 1;
      padding: var(--sp-5) 0 var(--sp-4);
    }

    .hero-visual {
      order: 2;
      height: auto;
      justify-content: center;
    }

    .hero-frame { margin-top: 0; }
  }

  @media (max-width: 480px) {
    .hero-actions { align-items: flex-start; flex-direction: column; gap: var(--sp-3); }
  }
</style>
