---
const featured = {
  quote: 'A Filos transformou meu manuscrito numa obra que me orgulha. O processo foi tranquilo, profissional e o resultado superou todas as minhas expectativas. Meu livro está hoje em 40 plataformas!',
  name: 'Ana Carvalho',
  role: 'Autora de Ficção Científica',
};

const others = [
  {
    quote: 'Como pesquisador acadêmico, precisava de um parceiro que entendesse a seriedade do processo editorial. A Filos entregou tudo dentro do prazo, com DOI Internacional e ficha catalográfica impecável.',
    name: 'Dr. Marcos Silveira',
    role: 'Pesquisador, UFPE',
  },
  {
    quote: 'Publiquei meu primeiro livro com a Filos e não poderia ter escolhido melhor. O design da capa é lindo, a distribuição é global e o suporte da equipe foi incrível durante todo o processo.',
    name: 'Júlia Mendes',
    role: 'Escritora, gênero romance',
  },
];
---

<section class="testi" id="depoimentos">
  <div class="container">
    <p class="meta testi-kicker reveal">O que nossos autores dizem</p>

    <figure class="testi-featured reveal">
      <blockquote>
        <p>“{featured.quote}”</p>
      </blockquote>
      <figcaption>
        <span class="testi-name">{featured.name}</span>
        <span class="meta">{featured.role}</span>
      </figcaption>
    </figure>

    <div class="testi-pair">
      {others.map((t, i) => (
        <figure class="testi-small reveal" style={`transition-delay:${0.1 + i * 0.08}s`}>
          <blockquote>
            <p>“{t.quote}”</p>
          </blockquote>
          <figcaption>
            <span class="testi-name">{t.name}</span>
            <span class="meta">{t.role}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .testi {
    padding: clamp(89px, 13vw, 155px) 0;
    background: var(--terra);
  }

  .testi-kicker {
    margin-bottom: var(--sp-5);
    padding-bottom: var(--sp-2);
    border-bottom: 1px solid rgba(255,255,255,0.25);
    max-width: max-content;
    color: rgba(255,255,255,0.6);
  }

  .testi-featured { margin-bottom: var(--sp-6); }

  .testi-featured blockquote p {
    font-family: var(--f-display);
    font-weight: 300;
    font-size: clamp(1.45rem, 3vw, 2.3rem);
    line-height: 1.32;
    letter-spacing: -0.014em;
    color: #fff;
    max-width: 26em;
    text-wrap: balance;
  }

  figcaption {
    margin-top: var(--sp-3);
    display: flex;
    align-items: baseline;
    gap: 13px;
  }

  .testi-name {
    font-family: var(--f-display);
    font-weight: 600;
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.9);
  }

  figcaption .meta {
    color: rgba(255,255,255,0.55);
  }

  figcaption .meta::before {
    content: '—';
    margin-right: 8px;
  }

  .testi-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(34px, 6vw, 89px);
    border-top: 1px solid rgba(255,255,255,0.2);
    padding-top: var(--sp-5);
    position: relative;
  }

  .testi-pair::before {
    content: '';
    position: absolute;
    top: var(--sp-5);
    bottom: 0;
    left: 50%;
    width: 1px;
    background: rgba(255,255,255,0.15);
  }

  .testi-small blockquote p {
    font-style: italic;
    font-size: 0.99rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.8;
  }

  .testi-small figcaption { margin-top: var(--sp-2); }

  @media (max-width: 760px) {
    .testi-pair { grid-template-columns: 1fr; gap: var(--sp-5); }
    .testi-pair::before { display: none; }
    .testi-small + .testi-small {
      border-top: 1px solid rgba(255,255,255,0.15);
      padding-top: var(--sp-5);
    }
  }
</style>
