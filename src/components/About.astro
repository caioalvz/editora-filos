---
import site from '../data/site.json';
---
<section class="about-section dot-bg" id="sobre">
  <div class="container">
    <div class="about-inner">

      <!-- Ilustração editorial -->
      <div class="about-visual pop-in">
        <div class="about-img-wrap">
          <svg viewBox="0 0 400 500" xmlns="http://www.w3.org/2000/svg" width="100%" style="display:block;aspect-ratio:4/5;">
            <defs>
              <linearGradient id="wall-grad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#F2F2F2"/>
                <stop offset="100%" stop-color="#E8E8E8"/>
              </linearGradient>
              <linearGradient id="desk-grad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#AAAAAA"/>
                <stop offset="100%" stop-color="#999999"/>
              </linearGradient>
            </defs>
            <!-- wall -->
            <rect width="400" height="500" fill="url(#wall-grad)"/>
            <!-- floor -->
            <rect x="0" y="360" width="400" height="140" fill="#BBBBBB" opacity="0.3"/>
            <!-- bookshelf -->
            <rect x="280" y="30" width="110" height="200" rx="4" fill="#AAAAAA" opacity="0.4"/>
            <rect x="280" y="100" width="110" height="5" rx="2" fill="#888888" opacity="0.5"/>
            <rect x="280" y="168" width="110" height="5" rx="2" fill="#888888" opacity="0.5"/>
            <!-- shelf books row 1 -->
            <rect x="286" y="36" width="12" height="62" rx="1" fill="#222222"/>
            <rect x="300" y="42" width="9"  height="56" rx="1" fill="#555555"/>
            <rect x="311" y="36" width="14" height="62" rx="1" fill="#888888"/>
            <rect x="327" y="40" width="10" height="58" rx="1" fill="#333333"/>
            <rect x="339" y="36" width="13" height="62" rx="1" fill="#AAAAAA"/>
            <rect x="354" y="43" width="9"  height="55" rx="1" fill="#666666"/>
            <rect x="365" y="37" width="16" height="61" rx="1" fill="#444444" opacity="0.7"/>
            <!-- shelf books row 2 -->
            <rect x="286" y="108" width="14" height="58" rx="1" fill="#777777"/>
            <rect x="302" y="112" width="10" height="54" rx="1" fill="#333333"/>
            <rect x="314" y="106" width="16" height="60" rx="1" fill="#999999"/>
            <rect x="332" y="110" width="12" height="56" rx="1" fill="#555555"/>
            <rect x="346" y="108" width="10" height="58" rx="1" fill="#111111" opacity="0.6"/>
            <rect x="358" y="112" width="18" height="54" rx="1" fill="#BBBBBB"/>
            <!-- plant -->
            <rect x="286" y="222" width="18" height="14" rx="3" fill="#888888" opacity="0.7"/>
            <ellipse cx="295" cy="216" rx="16" ry="18" fill="#AAAAAA" opacity="0.7"/>
            <ellipse cx="287" cy="210" rx="10" ry="12" fill="#888888" opacity="0.6"/>
            <ellipse cx="303" cy="209" rx="10" ry="12" fill="#999999"/>
            <!-- window -->
            <rect x="30" y="30" width="130" height="130" rx="8" fill="#EEEEEE" stroke="#CCCCCC" stroke-width="2"/>
            <line x1="95" y1="30" x2="95"  y2="160" stroke="#CCCCCC" stroke-width="2"/>
            <line x1="30" y1="95" x2="160" y2="95"  stroke="#CCCCCC" stroke-width="2"/>
            <!-- desk -->
            <rect x="20" y="300" width="380" height="70" rx="6" fill="url(#desk-grad)"/>
            <rect x="20" y="295" width="380" height="14" rx="4" fill="#BBBBBB"/>
            <rect x="40"  y="370" width="16" height="50" rx="4" fill="#999999"/>
            <rect x="344" y="370" width="16" height="50" rx="4" fill="#999999"/>
            <!-- laptop -->
            <rect x="130" y="240" width="160" height="100" rx="6" fill="#111111"/>
            <rect x="136" y="246" width="148" height="88" rx="4" fill="#2A2A2A"/>
            <rect x="144" y="254" width="132" height="12" rx="2" fill="#444444" opacity="0.9"/>
            <rect x="144" y="270" width="90"  height="6" rx="2" fill="#555555" opacity="0.5"/>
            <rect x="144" y="280" width="110" height="6" rx="2" fill="#555555" opacity="0.4"/>
            <rect x="144" y="290" width="78"  height="6" rx="2" fill="#555555" opacity="0.3"/>
            <rect x="144" y="306" width="132" height="20" rx="3" fill="#333333" opacity="0.4"/>
            <rect x="110" y="340" width="200" height="12" rx="4" fill="#2A2A2A"/>
            <rect x="165" y="352" width="90"  height="5"  rx="2" fill="#333333"/>
            <!-- coffee mug -->
            <rect x="60" y="265" width="40" height="42" rx="8" fill="#333333" opacity="0.85"/>
            <path d="M100,278 Q114,278 114,286 Q114,294 100,294" fill="none" stroke="#333333" stroke-width="4" opacity="0.85"/>
            <rect x="65" y="260" width="30" height="8" rx="4" fill="#EEEEEE"/>
            <path d="M75,252 Q77,244 75,238" fill="none" stroke="#BBBBBB" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M85,250 Q87,242 85,236" fill="none" stroke="#BBBBBB" stroke-width="2.5" stroke-linecap="round"/>
            <!-- open pages -->
            <rect x="260" y="262" width="120" height="80" rx="4" fill="#FAFAF8" stroke="#DDDDDD" stroke-width="1.5" transform="rotate(-3 320 302)"/>
            <line x1="272" y1="278" x2="368" y2="276" stroke="#DDDDDD" stroke-width="1.5" stroke-linecap="round" transform="rotate(-3 320 302)"/>
            <line x1="272" y1="289" x2="365" y2="287" stroke="#DDDDDD" stroke-width="1.5" stroke-linecap="round" transform="rotate(-3 320 302)"/>
            <line x1="272" y1="300" x2="355" y2="298" stroke="#DDDDDD" stroke-width="1.5" stroke-linecap="round" transform="rotate(-3 320 302)"/>
            <line x1="272" y1="311" x2="368" y2="309" stroke="#DDDDDD" stroke-width="1.5" stroke-linecap="round" transform="rotate(-3 320 302)"/>
            <!-- person 1 -->
            <circle cx="210" cy="195" r="32" fill="#999999" opacity="0.7"/>
            <circle cx="210" cy="182" r="18" fill="#BBBBBB"/>
            <ellipse cx="210" cy="230" rx="30" ry="20" fill="#333333"/>
            <ellipse cx="210" cy="170" rx="20" ry="14" fill="#111111"/>
            <circle cx="204" cy="182" r="2.5" fill="#111111"/>
            <circle cx="216" cy="182" r="2.5" fill="#111111"/>
            <!-- person 2 -->
            <circle cx="85" cy="205" r="28" fill="#BBBBBB" opacity="0.7"/>
            <circle cx="85" cy="194" r="16" fill="#CCCCCC"/>
            <ellipse cx="85" cy="236" rx="28" ry="18" fill="#555555"/>
            <ellipse cx="85" cy="183" rx="18" ry="12" fill="#444444"/>
            <circle cx="79" cy="194" r="2" fill="#111111"/>
            <circle cx="91" cy="194" r="2" fill="#111111"/>
            <!-- speech bubble -->
            <rect x="108" y="148" width="80" height="40" rx="10" fill="#FFFFFF" stroke="#DDDDDD" stroke-width="1.5"/>
            <polygon points="120,188 134,188 127,200" fill="#FFFFFF"/>
            <polygon points="120,189 134,189 127,201" fill="#DDDDDD"/>
            <line x1="118" y1="162" x2="178" y2="162" stroke="#333333" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="118" y1="172" x2="160" y2="172" stroke="#333333" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="182" cy="162" r="4" fill="#666666"/>
          </svg>
        </div>
        <div class="about-float">
          <span class="num">{site.yearsExperience}</span>
          <span class="label">Anos de experiência</span>
        </div>
        <div class="about-float2">
          <span class="num2">100%</span>
          <span class="label2">Dedicação</span>
        </div>
      </div>

      <!-- Texto + stats -->
      <div class="about-text fade-up">
        <span class="section-label">Nossa história</span>
        <h2 class="section-title">Nascemos para<br />publicar histórias</h2>
        <p style="color:var(--muted-fg);margin-bottom:1.5rem;">
          A Filos Editora nasceu da convicção de que todo autor merece um parceiro editorial que entende tanto do processo criativo quanto do mercado literário.
        </p>
        <p style="color:var(--muted-fg);margin-bottom:2rem;">
          Com mais de 15 anos de atuação, já ajudamos centenas de autores independentes a publicarem com qualidade, profissionalismo e a satisfação de ver suas histórias nas mãos de leitores de verdade.
        </p>
        <div class="about-stats">
          <div class="stat-box">
            <span class="stat-num" style="color:var(--accent);">{site.authorsServed}</span>
            <span class="stat-label">Autores atendidos</span>
          </div>
          <div class="stat-box">
            <span class="stat-num" style="color:var(--secondary);">{site.titlesPublished}</span>
            <span class="stat-label">Títulos publicados</span>
          </div>
          <div class="stat-box">
            <span class="stat-num" style="color:var(--tertiary);">{site.yearsExperience}</span>
            <span class="stat-label">Anos de mercado</span>
          </div>
          <div class="stat-box">
            <span class="stat-num" style="color:var(--quaternary);">{site.satisfactionRate}</span>
            <span class="stat-label">Satisfação de clientes</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
