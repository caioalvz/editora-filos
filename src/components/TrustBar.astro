---
const logos = [
  { src: '/images/logos/amazon.svg',          alt: 'Amazon' },
  { src: '/images/logos/google-books.svg',    alt: 'Google Books' },
  { src: '/images/logos/apple-books.svg',     alt: 'Apple Books' },
  { src: '/images/logos/kobo.svg',            alt: 'Kobo' },
  { src: '/images/logos/scribd.svg',          alt: 'Scribd' },
  { src: '/images/logos/overdrive.svg',       alt: 'OverDrive' },
  { src: '/images/logos/barnes-noble.svg',    alt: 'Barnes & Noble' },
  { src: '/images/logos/livraria-cultura.svg',alt: 'Livraria Cultura' },
  { src: '/images/logos/saraiva.svg',         alt: 'Saraiva' },
  { src: '/images/logos/fnac.svg',            alt: 'Fnac' },
  { src: '/images/logos/estante-virtual.svg', alt: 'Estante Virtual' },
  { src: '/images/logos/clube-autores.svg',   alt: 'Clube de Autores' },
];
---

<div class="trust-strip">
  <div class="trust-inner container">
    <span class="trust-label">+40 plataformas</span>
    <div class="trust-track-wrap" aria-label="Plataformas parceiras">
      <div class="trust-track">
        {logos.map(l => (
          <img class="trust-logo" src={l.src} alt={l.alt} height="28" loading="lazy" decoding="async" />
        ))}
        {logos.map(l => (
          <img class="trust-logo" src={l.src} alt="" height="28" aria-hidden="true" loading="lazy" decoding="async" />
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .trust-strip {
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding: 18px 0;
    overflow: hidden;
    background: var(--navy);
  }

  .trust-inner {
    display: flex;
    align-items: center;
    gap: 34px;
  }

  .trust-label {
    white-space: nowrap;
    flex-shrink: 0;
    font-family: var(--f-text);
    font-size: 0.8rem;
    font-style: italic;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.01em;
  }

  .trust-track-wrap {
    overflow: hidden;
    flex: 1;
    mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
  }

  .trust-track {
    display: flex;
    align-items: center;
    gap: 55px;
    width: max-content;
    animation: scroll-track 40s linear infinite;
  }

  .trust-logo {
    height: 28px;
    width: auto;
    opacity: 0.7;
    filter: brightness(0) invert(1);
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .trust-logo:hover { opacity: 1; }

  @keyframes scroll-track {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .trust-track { animation: none; }
  }

  @media (max-width: 600px) {
    .trust-label { display: none; }
  }
</style>
