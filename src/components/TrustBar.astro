---
const platforms = [
  'Amazon', 'Google Books', 'Apple Books', 'Kobo', 'Rakuten',
  'Livraria Cultura', 'Saraiva', 'Barnes & Noble', 'Scribd', 'OverDrive',
  'Fnac', 'Estante Virtual', 'Clube de Autores', 'Smashwords', 'Draft2Digital',
];
---

<div class="trust-strip">
  <div class="trust-inner container">
    <span class="trust-label meta">Distribuição em +40 plataformas&ensp;—</span>
    <div class="trust-track-wrap" aria-hidden="true">
      <div class="trust-track">
        {platforms.map(p => <span class="trust-item">{p}</span>)}
        {platforms.map(p => <span class="trust-item" aria-hidden="true">{p}</span>)}
      </div>
    </div>
  </div>
</div>

<style>
  .trust-strip {
    border-bottom: 1px solid var(--line);
    padding: 15px 0;
    overflow: hidden;
    background: var(--ink-8);
  }

  .trust-inner {
    display: flex;
    align-items: baseline;
    gap: 21px;
  }

  .trust-label {
    white-space: nowrap;
    flex-shrink: 0;
    font-style: italic;
  }

  .trust-track-wrap {
    overflow: hidden;
    flex: 1;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  .trust-track {
    display: flex;
    align-items: baseline;
    width: max-content;
    animation: scroll-track 38s linear infinite;
  }

  .trust-item {
    font-family: var(--f-text);
    font-style: italic;
    font-size: 0.84rem;
    color: var(--ink-3);
    white-space: nowrap;
  }

  .trust-item::after {
    content: '·';
    margin: 0 1.1em;
    color: var(--ink-5);
    font-style: normal;
  }

  @keyframes scroll-track {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .trust-track { animation: none; }
  }

  @media (max-width: 600px) {
    .trust-label { display: none; }
  }
</style>
