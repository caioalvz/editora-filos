---

<div class="trust-strip">
  <div class="trust-inner container">
    <span class="trust-label">+40 plataformas</span>
    <div class="trust-track-wrap" aria-label="Plataformas de distribuição parceiras">
      <div class="trust-track">
        {logos.map(l => (
          <span class="trust-logo" title={l.name}>
            <svg
              viewBox={`0 0 ${l.w} ${l.h}`}
              height="28"
              style="display:block;width:auto;flex-shrink:0"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              set:html={l.body}
            />
          </span>
        ))}
        {/* duplicate set for seamless loop */}
        {logos.map(l => (
          <span class="trust-logo" aria-hidden="true">
            <svg
              viewBox={`0 0 ${l.w} ${l.h}`}
              height="28"
              style="display:block;width:auto;flex-shrink:0"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              set:html={l.body}
            />
          </span>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .trust-strip {
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding: 18px 0;
    overflow: hidden;
    background: var(--navy);
  }

  .trust-inner {
    display: flex;
    align-items: center;
    gap: 34px;
  }

  .trust-label {
    white-space: nowrap;
    flex-shrink: 0;
    font-family: var(--f-text);
    font-size: 0.78rem;
    font-style: italic;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.01em;
  }

  .trust-track-wrap {
    overflow: hidden;
    flex: 1;
    mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 6%, black 94%, transparent);
  }

  .trust-track {
    display: flex;
    align-items: center;
    gap: 55px;
    width: max-content;
    animation: scroll-track 44s linear infinite;
    /* color herdado pelos SVGs via fill="currentColor" */
    color: rgba(255,255,255,0.65);
  }

  .trust-logo {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    transition: color 0.2s;
    cursor: default;
  }

  .trust-logo:hover { color: rgba(255,255,255,1); }

  @keyframes scroll-track {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .trust-track { animation: none; }
  }

  @media (max-width: 600px) {
    .trust-label { display: none; }
  }
</style>
