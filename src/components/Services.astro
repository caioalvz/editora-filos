---
const services = [
  {
    phase: 'Primeira fase',
    title: 'Design Premium',
    desc: 'Identidade visual completa para sua obra. Capa profissional, diagramação editorial e tipografia que fazem seu livro se destacar em qualquer prateleira.',
    feats: ['Capa exclusiva autoral', 'Diagramação editorial profissional', 'Tipografia e espaçamento precisos', 'Versões para impressão e digital', 'Revisão ilimitada até aprovação'],
  },
  {
    phase: 'Segunda fase',
    title: 'ISBN, Ficha & DOI',
    desc: 'Registro completo e legítimo da sua obra. ISBN, ficha catalográfica e DOI Internacional para garantir a identidade acadêmica e comercial do seu livro.',
    feats: ['ISBN nacional e internacional', 'Ficha catalográfica oficial', 'DOI Internacional (Crossref)', 'Depósito legal junto à Biblioteca Nacional', 'Certificado de registro da obra'],
  },
  {
    phase: 'Terceira fase',
    title: 'Impressão & Distribuição Global',
    desc: 'Seu livro disponível para o mundo. Impressão sob demanda com qualidade editorial e distribuição simultânea em mais de 40 plataformas internacionais.',
    feats: ['Impressão sob demanda (POD)', 'Distribuição em +40 plataformas', 'Amazon, Google Books, Apple Books', 'Kobo, Scribd, OverDrive e mais', 'Versões eBook (ePub) e impresso'],
  },
  {
    phase: 'Quarta fase',
    title: 'Posicionamento & Lançamento',
    desc: 'Estratégia de marketing editorial para ampliar o alcance da sua obra. Presença digital, relações com imprensa e suporte ao lançamento.',
    feats: ['Estratégia de lançamento editorial', 'Press release e assessoria de imprensa', 'Posicionamento em mecanismos de busca', 'Perfil do autor nas plataformas', 'Suporte pós-publicação'],
  },
];
---

<section class="services" id="servicos">
  <div class="container">
    <header class="services-head reveal">
      <h2>A jornada completa<br />do seu livro</h2>
      <p class="prose services-sub">
        Do rascunho ao livro publicado globalmente. Cada fase foi desenhada para
        garantir qualidade, identidade e alcance para a sua obra.
      </p>
    </header>

    <div class="services-index">
      {services.map((s, i) => {
        const variants = ['navy', 'light', 'dark', 'warm'] as const;
        const v = variants[i % 4];
        return (
        <article class={`chapter reveal chapter--${v}`} style={`transition-delay:${i * 0.08}s`}>
          <div class="ch-meta">
            <span class="meta">{s.phase}</span>
          </div>

          <div class="ch-body">
            <h3 class="ch-title">{s.title}</h3>
            <p class="prose ch-desc">{s.desc}</p>
            <a
              href={`https://wa.me/5581999999999?text=Olá!%20Tenho%20interesse%20na%20${encodeURIComponent(s.title)}%20da%20Filos.`}
              class="link-line ch-link"
              target="_blank"
              rel="noopener"
              aria-label={`Saber mais sobre ${s.title}`}
            >
              Saber mais
            </a>
          </div>

          <ul class="ch-feats">
            {s.feats.map(f => <li>{f}</li>)}
          </ul>
        </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .services {
    padding: clamp(89px, 12vw, 144px) 0 clamp(55px, 9vw, 110px);
  }

  .services-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--sp-5);
    margin-bottom: var(--sp-6);
  }

  .services-sub { max-width: 42ch; }

  /* índice de capítulos */
  .services-index {
    border-top: 1px solid var(--line-strong);
  }

  .chapter {
    display: grid;
    grid-template-columns: 150px 1fr 270px;
    gap: var(--sp-5);
    padding: var(--sp-5) var(--sp-4);
    border-bottom: 1px solid var(--line);
    transition: background var(--dur) var(--ease-out);
  }

  /* ── variantes de cor ── */
  .chapter--navy {
    background: var(--navy);
    border-bottom-color: rgba(255,255,255,0.1);
  }
  .chapter--navy .meta,
  .chapter--navy .ch-title,
  .chapter--navy .ch-desc,
  .chapter--navy .ch-feats li,
  .chapter--navy .ch-link { color: rgba(255,255,255,0.85); }
  .chapter--navy .meta { color: var(--teal); }
  .chapter--navy .ch-title { color: #fff; }
  .chapter--navy .ch-feats li::before { color: rgba(255,255,255,0.35); }
  .chapter--navy .ch-link { border-bottom-color: rgba(255,255,255,0.3); }
  .chapter--navy .ch-link:hover { color: #fff; border-bottom-color: #fff; }
  .chapter--navy:hover { background: var(--navy-light); }

  .chapter--dark {
    background: var(--ink-0);
    border-bottom-color: rgba(255,255,255,0.08);
  }
  .chapter--dark .meta { color: var(--amber); }
  .chapter--dark .ch-title { color: #fff; }
  .chapter--dark .ch-desc,
  .chapter--dark .ch-feats li { color: rgba(255,255,255,0.7); }
  .chapter--dark .ch-feats li::before { color: rgba(255,255,255,0.3); }
  .chapter--dark .ch-link { color: rgba(255,255,255,0.85); border-bottom-color: rgba(255,255,255,0.3); }
  .chapter--dark .ch-link:hover { color: #fff; border-bottom-color: #fff; }
  .chapter--dark:hover { background: #1a1917; }

  .chapter--warm {
    background: var(--amber-mute);
    border-bottom-color: rgba(180,130,60,0.2);
  }
  .chapter--warm .meta { color: var(--navy); }
  .chapter--warm:hover { background: #eddfc5; }

  .chapter--light:hover { background: var(--ink-8); }

  .ch-meta { padding-top: 0.55rem; }

  .ch-title {
    font-size: clamp(1.5rem, 2.6vw, 2.1rem);
    font-weight: 500;
    margin-bottom: var(--sp-2);
  }

  .ch-desc {
    font-size: 0.97rem;
    max-width: 52ch;
    margin-bottom: var(--sp-3);
  }

  .ch-link { font-size: 0.875rem; }

  .ch-feats {
    padding-top: 0.55rem;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ch-feats li {
    font-size: 0.84rem;
    color: var(--ink-2);
    line-height: 1.55;
    padding-left: 19px;
    position: relative;
  }

  .ch-feats li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--ink-3);
  }

  @media (max-width: 1000px) {
    .chapter { grid-template-columns: 130px 1fr; }
    .ch-feats { grid-column: 2; padding-top: var(--sp-3); }
  }

  @media (max-width: 700px) {
    .services-head { flex-direction: column; align-items: flex-start; gap: var(--sp-3); margin-bottom: var(--sp-5); }
    .chapter { grid-template-columns: 1fr; gap: var(--sp-2); padding: var(--sp-4) var(--sp-3); }
    .ch-feats { grid-column: 1; }
  }
</style>
