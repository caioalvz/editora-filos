---
import services from '../data/services.json';
import site from '../data/site.json';
---
<section class="services-section" id="servicos">
  <div class="container">
    <div class="fade-up">
      <span class="section-label">O que oferecemos</span>
      <h2 class="section-title">Serviços Editoriais</h2>
      <p class="section-sub">Cada serviço foi pensado para um momento específico da sua jornada como autor — do texto bruto à obra nas prateleiras.</p>
    </div>
    <div class="services-grid">
      {services.map((s, i) => (
        <div class="service-card fade-up" style={"box-shadow:" + ({"revisao":"6px 6px 0 #666666","diagramacao":"6px 6px 0 #999999","capa":"6px 6px 0 #AAAAAA","isbn":"6px 6px 0 #333333","ebook":"6px 6px 0 #666666","consultoria":"6px 6px 0 #999999"})[s.id]}>
          <div class="service-card-tag" style={"background:"+s.tag.bg+";color:"+s.tag.color}>{s.tag.label}</div>
          <div class="service-icon-ring" style={"background:"+s.iconColor}>
            <svg viewBox="0 0 24 24" set:html={{"revisao":"<path d='M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7'/><path d='M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z'/>","diagramacao":"<rect x='3' y='3' width='18' height='18' rx='2'/><path d='M3 9h18M9 21V9'/>","capa":"<circle cx='12' cy='12' r='10'/><path d='M8 14s1.5 2 4 2 4-2 4-2'/>","isbn":"<path d='M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z'/><polyline points='14 2 14 8 20 8'/>","ebook":"<rect x='5' y='2' width='14' height='20' rx='2'/><line x1='9' y1='7' x2='15' y2='7'/>","consultoria":"<path d='M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z'/>"}[s.id]}></svg>
          </div>
          <h3>{s.title}</h3>
          <p>{s.description}</p>
          <ul class="service-features">
            {s.features.map(f => (
              <li>
                <span class="feature-check" style={"background:"+s.iconColor}>
                  <svg viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                </span>
                {f}
              </li>
            ))}
          </ul>
          <a href={"https://wa.me/"+site.whatsapp+"?text="+encodeURIComponent(s.waMessage)}
             class="btn-primary" style={"font-size:14px;padding:10px 20px;background:"+s.iconColor}
             target="_blank" rel="noopener">
            {s.cta}
            <span class="btn-icon"><svg viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></span>
          </a>
          <div class="service-card-deco" style={"background:"+s.iconColor}></div>
        </div>
      ))}
    </div>
  </div>
</section>