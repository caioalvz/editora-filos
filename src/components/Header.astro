---
---
<header id="site-header">
  <div class="header-inner container">
    <a href="/" class="logo-link" aria-label="Filos Editora — página inicial">
      <img class="logo" src="/images/logo-white.webp" alt="Filos Editora" width="120" height="44" />
    </a>

    <nav class="desktop-nav" aria-label="Navegação principal">
      <a href="#servicos">Serviços</a>
      <a href="#sobre">Sobre</a>
      <a href="#depoimentos">Depoimentos</a>
      <a href="#faq">Perguntas</a>
      <a href="#contato">Contato</a>
    </nav>

    <div class="header-actions">
      <a
        href="https://wa.me/5581999999999?text=Olá%2C%20quero%20publicar%20meu%20livro%20com%20a%20Filos!"
        class="header-cta"
        target="_blank"
        rel="noopener"
      >
        Publicar meu livro
        <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
      </a>

      <button
        id="hamburger"
        class="hamburger"
        aria-label="Abrir menu de navegação"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Menu mobile">
    <a href="#servicos"    class="mobile-link">Serviços</a>
    <a href="#sobre"       class="mobile-link">Sobre</a>
    <a href="#depoimentos" class="mobile-link">Depoimentos</a>
    <a href="#faq"         class="mobile-link">Perguntas</a>
    <a href="#contato"     class="mobile-link">Contato</a>
    <a
      href="https://wa.me/5581999999999?text=Olá%2C%20quero%20publicar%20meu%20livro%20com%20a%20Filos!"
      class="btn-fill mobile-cta"
      target="_blank"
      rel="noopener"
    >
      Publicar meu livro
    </a>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom: 1px solid transparent;
    transition: background 0.35s var(--ease-out), border-color 0.35s var(--ease-out);
  }

  header.scrolled {
    background: rgba(255,255,255,.94);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: var(--line);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 21px;
    height: 74px;
  }

  .logo-link { display: flex; align-items: center; flex-shrink: 0; }
  .logo {
    height: 38px;
    width: auto;
    filter: brightness(0) invert(1);
    transition: filter 0.35s var(--ease-out);
  }
  header.scrolled .logo { filter: brightness(0); }

  .desktop-nav {
    display: flex;
    align-items: baseline;
    gap: 34px;
    margin-left: auto;
  }

  .desktop-nav a {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.75);
    transition: color var(--dur);
  }

  .desktop-nav a:hover { color: #fff; }

  header.scrolled .desktop-nav a { color: var(--ink-2); }
  header.scrolled .desktop-nav a:hover { color: var(--ink-0); }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 13px;
    flex-shrink: 0;
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--f-display);
    font-weight: 500;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.85);
    border-bottom: 1px solid rgba(255,255,255,0.3);
    padding-bottom: 2px;
    transition: color var(--dur), border-color var(--dur);
  }

  .header-cta:hover { color: #fff; border-color: rgba(255,255,255,0.7); }

  header.scrolled .header-cta { color: var(--tone); border-color: var(--line-strong); }
  header.scrolled .header-cta:hover { color: var(--ink-0); border-color: var(--ink-0); }

  .header-cta svg {
    width: 15px; height: 15px;
    fill: none; stroke: currentColor; stroke-width: 2;
    stroke-linecap: round; stroke-linejoin: round;
    transition: transform var(--dur);
  }

  .header-cta:hover svg { transform: translateX(3px); }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 7px;
    padding: 12px 8px;
  }

  .hamburger span {
    display: block;
    width: 26px;
    height: 1.5px;
    background: #fff;
    transition: transform var(--dur) var(--ease-out), opacity var(--dur), background var(--dur);
  }

  header.scrolled .hamburger span { background: var(--ink-1); }

  /* Mobile nav */
  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 13px 22px 26px;
    background: var(--ink-8);
    border-top: 1px solid var(--line);
  }

  .mobile-nav.open { display: flex; }

  .mobile-link {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 1.1rem;
    color: var(--ink-2);
    padding: 13px 0;
    border-bottom: 1px solid var(--line);
    transition: color var(--dur);
  }

  .mobile-link:hover { color: var(--ink-0); }

  .mobile-cta {
    margin-top: 21px;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .desktop-nav { display: none; }
    .hamburger   { display: flex; }
    .header-cta  { display: none; }
  }
</style>

<script>
  const header = document.getElementById('site-header')!;

  const onScroll = () => {
    header.classList.toggle('scrolled', window.scrollY > 60);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const hamburger = document.getElementById('hamburger')!;
  const mobileNav = document.getElementById('mobile-nav')!;

  hamburger.addEventListener('click', () => {
    const open = mobileNav.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(open));
    const spans = hamburger.querySelectorAll('span');
    if (open) {
      spans[0].style.transform = 'translateY(4.5px) rotate(45deg)';
      spans[1].style.transform = 'translateY(-4.5px) rotate(-45deg)';
    } else {
      spans.forEach(s => { s.style.transform = ''; });
    }
  });

  document.querySelectorAll('.mobile-link, .mobile-cta').forEach(link => {
    link.addEventListener('click', () => {
      mobileNav.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.querySelectorAll('span').forEach(s => { s.style.transform = ''; });
    });
  });
</script>
