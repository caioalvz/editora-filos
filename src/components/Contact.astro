---
---
<section class="contact-section" id="contato">
  <div class="container">
    <div class="contact-header animate-on-scroll">
      <span class="section-eyebrow">Fale conosco</span>
      <h2>VAMOS CONVERSAR<br /><span class="highlight">SOBRE SEU LIVRO</span></h2>
    </div>

    <div class="contact-inner">
      <!-- Info -->
      <div class="contact-info animate-on-scroll">
        <h3>Canais de atendimento</h3>
        <p>Nossa equipe está pronta para ouvir sobre o seu projeto e indicar o melhor caminho editorial. Respondemos em até 24 horas úteis.</p>

        <div class="contact-links">
          <a
            href="https://wa.me/5581999999999?text=Olá!%20Vim%20pelo%20site%20da%20Filos%20Editora."
            class="contact-link"
            target="_blank"
            rel="noopener"
            aria-label="Falar pelo WhatsApp"
          >
            <div class="c-icon c-icon-wa" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </div>
            <div class="c-info">
              <span class="c-label">WhatsApp</span>
              <span class="c-value">(81) 99999-9999</span>
            </div>
            <svg class="c-arrow" viewBox="0 0 24 24" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </a>

          <a
            href="mailto:contato@filoseditora.com.br"
            class="contact-link"
            aria-label="Enviar e-mail"
          >
            <div class="c-icon c-icon-mail" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>
            </div>
            <div class="c-info">
              <span class="c-label">E-mail</span>
              <span class="c-value">contato@filoseditora.com.br</span>
            </div>
            <svg class="c-arrow" viewBox="0 0 24 24" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </a>

          <a
            href="https://instagram.com/filoseditora"
            class="contact-link"
            target="_blank"
            rel="noopener"
            aria-label="Instagram Filos Editora"
          >
            <div class="c-icon c-icon-ig" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </div>
            <div class="c-info">
              <span class="c-label">Instagram</span>
              <span class="c-value">@filoseditora</span>
            </div>
            <svg class="c-arrow" viewBox="0 0 24 24" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>

        <div class="contact-hours">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Atendimento de segunda a sexta, das 9h às 18h
        </div>
      </div>

      <!-- Form -->
      <div class="contact-form-wrap animate-on-scroll" style="transition-delay:.15s">
        <h3>Envie uma mensagem</h3>
        <p>Preencha abaixo e envie pelo WhatsApp — é mais rápido!</p>

        <div class="form-body">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="cName">Nome</label>
              <input type="text" id="cName" class="form-input" placeholder="Seu nome completo" required autocomplete="name" />
            </div>
            <div class="form-group">
              <label class="form-label" for="cEmail">E-mail</label>
              <input type="email" id="cEmail" class="form-input" placeholder="seu@email.com" required autocomplete="email" />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="cService">Serviço de interesse</label>
            <select id="cService" class="form-input" required>
              <option value="">Selecione uma fase...</option>
              <option value="Fase 1 — Design Premium">Fase 1 — Design Premium</option>
              <option value="Fase 2 — ISBN, Ficha e DOI">Fase 2 — ISBN, Ficha Catalográfica e DOI</option>
              <option value="Fase 3 — Impressão e Distribuição">Fase 3 — Impressão e Distribuição Global</option>
              <option value="Fase 4 — Posicionamento e Lançamento">Fase 4 — Posicionamento e Lançamento</option>
              <option value="Jornada Completa">Jornada Completa (todas as fases)</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="cMsg">Sobre seu projeto</label>
            <textarea
              id="cMsg"
              class="form-input"
              placeholder="Gênero, número de páginas, estágio atual do manuscrito..."
              rows="4"
              style="resize: vertical; min-height: 100px;"
            ></textarea>
          </div>

          <button class="btn-wa-send" type="button" id="send-wa-btn">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013 12.6a19.79 19.79 0 01-3.07-8.67A2 2 0 011.9 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            Enviar pelo WhatsApp
          </button>

          <p class="form-note">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Respondemos em até 24h úteis · Seus dados não são compartilhados
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    background: var(--bg2);
    border-top: 1px solid var(--border);
  }

  .contact-header { margin-bottom: 3rem; }
  .contact-header h2 { margin-bottom: 0.5rem; }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  /* Info */
  .contact-info h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .contact-info p {
    font-family: var(--f-body);
    font-size: 0.9rem;
    color: var(--text2);
    line-height: 1.72;
    margin-bottom: 1.5rem;
  }

  .contact-links { display: flex; flex-direction: column; gap: 10px; }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--text2);
    font-family: var(--f-titles);
    font-size: 0.88rem;
    font-weight: 600;
    padding: 14px 16px;
    border-radius: var(--r-lg);
    background: var(--bg3);
    border: 1px solid var(--border);
    box-shadow: var(--sh-sm);
    transition: all var(--dur) var(--ease);
    text-decoration: none;
    min-height: 60px;
  }

  .contact-link:hover {
    color: var(--text);
    border-color: var(--border2);
    transform: translateY(-2px);
    box-shadow: var(--sh-md);
  }

  .c-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--r-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .c-icon svg { width: 18px; height: 18px; }

  .c-icon-wa   { background: #25D366; }
  .c-icon-wa svg { fill: white; stroke: none; }
  .c-icon-mail { background: var(--gold-bg); border: 1px solid var(--gold-bd); }
  .c-icon-mail svg { stroke: var(--gold); }
  .c-icon-ig   { background: var(--bg4); border: 1px solid var(--border2); }
  .c-icon-ig svg { stroke: var(--text2); }

  .c-info { flex: 1; display: flex; flex-direction: column; gap: 2px; }

  .c-label {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text3);
  }

  .c-value { font-size: 0.88rem; color: var(--text); }

  .c-arrow {
    width: 16px; height: 16px;
    fill: none; stroke: var(--text3); stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
    transition: transform var(--dur);
    flex-shrink: 0;
  }

  .contact-link:hover .c-arrow { transform: translateX(4px); stroke: var(--gold); }

  .contact-hours {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--f-titles);
    font-size: 0.75rem;
    color: var(--text3);
    margin-top: 1.25rem;
  }

  .contact-hours svg { stroke: var(--text3); flex-shrink: 0; }

  /* Form */
  .contact-form-wrap {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: 32px;
    box-shadow: var(--sh-sm);
  }

  .contact-form-wrap h3 { margin-bottom: 4px; }

  .contact-form-wrap > p {
    font-family: var(--f-body);
    font-size: 0.85rem;
    color: var(--text2);
    margin-bottom: 1.5rem;
  }

  .form-body { display: flex; flex-direction: column; gap: 14px; }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .form-group { display: flex; flex-direction: column; gap: 6px; }

  .form-label {
    font-family: var(--f-titles);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text3);
  }

  .form-input {
    width: 100%;
    background: var(--bg4);
    border: 1px solid var(--border2);
    border-radius: var(--r-md);
    padding: 11px 14px;
    font-family: var(--f-body);
    font-size: 0.9rem;
    color: var(--text);
    transition: border-color var(--dur), box-shadow var(--dur);
    outline: none;
    min-height: 44px;
  }

  .form-input::placeholder { color: var(--text3); }

  .form-input:focus {
    border-color: var(--gold-bd);
    box-shadow: 0 0 0 3px var(--gold-bg);
  }

  .form-input option { background: var(--bg4); color: var(--text); }

  /* Send button */
  .btn-wa-send {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    width: 100%;
    background: #25D366;
    color: white;
    font-family: var(--f-titles);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 15px 24px;
    border-radius: var(--r-pill);
    box-shadow: 0 6px 20px rgba(37,211,102,.30);
    transition: all var(--dur) var(--ease);
    cursor: pointer;
    border: none;
    min-height: 52px;
    margin-top: 4px;
  }

  .btn-wa-send:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(37,211,102,.45);
    filter: brightness(1.06);
  }

  .form-note {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--f-titles);
    font-size: 0.72rem;
    color: var(--text3);
    text-align: center;
    justify-content: center;
  }

  .form-note svg { stroke: var(--text3); flex-shrink: 0; }

  /* Responsive */
  @media (max-width: 900px) {
    .contact-inner { grid-template-columns: 1fr; gap: 40px; }
  }

  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
    .contact-form-wrap { padding: 24px 20px; }
  }
</style>

<script>
  document.getElementById('send-wa-btn')!.addEventListener('click', () => {
    const name    = (document.getElementById('cName')    as HTMLInputElement).value.trim();
    const email   = (document.getElementById('cEmail')   as HTMLInputElement).value.trim();
    const service = (document.getElementById('cService') as HTMLSelectElement).value;
    const msg     = (document.getElementById('cMsg')     as HTMLTextAreaElement).value.trim();

    let text = 'Olá!%20Quero%20publicar%20meu%20livro%20com%20a%20Filos.';
    if (name)    text += '%0ANome%3A%20'    + encodeURIComponent(name);
    if (email)   text += '%0AE-mail%3A%20'  + encodeURIComponent(email);
    if (service) text += '%0AServiço%3A%20' + encodeURIComponent(service);
    if (msg)     text += '%0AProjeto%3A%20' + encodeURIComponent(msg);

    window.open('https://wa.me/5581999999999?text=' + text, '_blank', 'noopener');
  });
</script>
