---
---
<section class="contact" id="contato">
  <div class="container">
    <header class="contact-head reveal">
      <h2>Vamos conversar<br />sobre seu livro</h2>
    </header>

    <div class="contact-inner">
      <!-- Canais -->
      <div class="contact-info reveal">
        <p class="prose contact-lede">Nossa equipe está pronta para ouvir sobre o seu projeto e indicar o melhor caminho editorial. Respondemos em até 24 horas úteis.</p>

        <ul class="contact-list">
          <li>
            <span class="meta">WhatsApp</span>
            <a
              href="https://wa.me/5581999999999?text=Olá!%20Vim%20pelo%20site%20da%20Filos%20Editora."
              class="contact-value"
              target="_blank"
              rel="noopener"
            >(81) 99999-9999</a>
          </li>
          <li>
            <span class="meta">E-mail</span>
            <a href="mailto:contato@filoseditora.com.br" class="contact-value">contato@filoseditora.com.br</a>
          </li>
          <li>
            <span class="meta">Instagram</span>
            <a href="https://instagram.com/filoseditora" class="contact-value" target="_blank" rel="noopener">@filoseditora</a>
          </li>
        </ul>

        <p class="meta contact-hours">Atendimento de segunda a sexta, das 9h às 18h.</p>
      </div>

      <!-- Formulário -->
      <div class="contact-form reveal" style="transition-delay:.1s">
        <p class="meta form-kicker">Envie uma mensagem — preencha abaixo e envie pelo WhatsApp, é mais rápido.</p>

        <div class="form-body">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="cName">Nome</label>
              <input type="text" id="cName" class="form-input" placeholder="Seu nome completo" required autocomplete="name" />
            </div>
            <div class="form-group">
              <label class="form-label" for="cEmail">E-mail</label>
              <input type="email" id="cEmail" class="form-input" placeholder="seu@email.com" required autocomplete="email" />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="cService">Serviço de interesse</label>
            <select id="cService" class="form-input" required>
              <option value="">Selecione uma fase...</option>
              <option value="Fase 1 — Design Premium">Primeira fase — Design Premium</option>
              <option value="Fase 2 — ISBN, Ficha e DOI">Segunda fase — ISBN, Ficha Catalográfica e DOI</option>
              <option value="Fase 3 — Impressão e Distribuição">Terceira fase — Impressão e Distribuição Global</option>
              <option value="Fase 4 — Posicionamento e Lançamento">Quarta fase — Posicionamento e Lançamento</option>
              <option value="Jornada Completa">Jornada Completa (todas as fases)</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="cMsg">Sobre seu projeto</label>
            <textarea
              id="cMsg"
              class="form-input"
              placeholder="Gênero, número de páginas, estágio atual do manuscrito..."
              rows="4"
            ></textarea>
          </div>

          <button class="btn-fill form-send" type="button" id="send-wa-btn">
            Enviar pelo WhatsApp
            <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
          </button>

          <p class="meta form-note">
            Respondemos em até 24h úteis &middot; Seus dados não são compartilhados.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--ink-8);
    border-top: 1px solid var(--line);
    padding: clamp(72px, 11vw, 130px) 0;
  }

  .contact-head { margin-bottom: var(--sp-5); }

  .contact-inner {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(34px, 7vw, 89px);
    align-items: start;
  }

  .contact-lede {
    font-size: 0.97rem;
    margin-bottom: var(--sp-4);
    max-width: 40ch;
  }

  .contact-list {
    border-top: 1px solid var(--line-strong);
  }

  .contact-list li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 21px;
    padding: 17px 0;
    border-bottom: 1px solid var(--line);
  }

  .contact-value {
    font-family: var(--f-display);
    font-weight: 500;
    font-size: 1rem;
    color: var(--ink-1);
    transition: color var(--dur);
  }

  .contact-value:hover { color: var(--tone); }

  .contact-hours { margin-top: var(--sp-3); }

  /* formulário editorial: campos de filete */
  .form-kicker {
    margin-bottom: var(--sp-4);
    max-width: 48ch;
  }

  .form-body { display: flex; flex-direction: column; gap: var(--sp-4); }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }

  .form-group { display: flex; flex-direction: column; gap: 7px; }

  .form-label {
    font-family: var(--f-display);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--ink-3);
  }

  .form-input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--line-strong);
    border-radius: 0;
    padding: 9px 0 11px;
    font-family: var(--f-text);
    font-size: 0.97rem;
    color: var(--ink-0);
    transition: border-color var(--dur);
    outline: none;
  }

  textarea.form-input { resize: vertical; min-height: 96px; }

  .form-input::placeholder { color: var(--ink-3); opacity: 1; }

  .form-input:focus { border-color: var(--tone); }

  select.form-input option { background: var(--ink-8); color: var(--ink-1); }

  .form-send { align-self: flex-start; }

  .form-note { margin-top: calc(-1 * var(--sp-2)); }

  @media (max-width: 900px) {
    .contact-inner { grid-template-columns: 1fr; gap: var(--sp-5); }
  }

  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.getElementById('send-wa-btn')!.addEventListener('click', () => {
    const name    = (document.getElementById('cName')    as HTMLInputElement).value.trim();
    const email   = (document.getElementById('cEmail')   as HTMLInputElement).value.trim();
    const service = (document.getElementById('cService') as HTMLSelectElement).value;
    const msg     = (document.getElementById('cMsg')     as HTMLTextAreaElement).value.trim();

    let text = 'Olá!%20Quero%20publicar%20meu%20livro%20com%20a%20Filos.';
    if (name)    text += '%0ANome%3A%20'    + encodeURIComponent(name);
    if (email)   text += '%0AE-mail%3A%20'  + encodeURIComponent(email);
    if (service) text += '%0AServiço%3A%20' + encodeURIComponent(service);
    if (msg)     text += '%0AProjeto%3A%20' + encodeURIComponent(msg);

    window.open('https://wa.me/5581999999999?text=' + text, '_blank', 'noopener');
  });
</script>
