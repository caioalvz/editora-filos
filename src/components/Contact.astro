---
import site from '../data/site.json';
const waHref = `https://wa.me/${site.whatsapp}`;
const igHref = `https://instagram.com/${site.instagram}`;
---
<section class="contact-section" id="contato">
  <div class="container">
    <div class="fade-up" style="margin-bottom:3rem;">
      <span class="section-label">Fale conosco</span>
      <h2 class="section-title">Vamos conversar<br />sobre seu livro</h2>
      <p class="section-sub">Preencha o formulário ou escolha o canal de contato que preferir. Respondemos em até 24 horas.</p>
    </div>

    <div class="contact-inner">
      <!-- Canais de atendimento -->
      <div class="contact-info fade-up">
        <h3>Canais de Atendimento</h3>
        <p>Escolha o canal que preferir. Nossa equipe está pronta para ouvir sobre o seu projeto e indicar o melhor caminho editorial.</p>
        <div class="contact-links">

          <a href={waHref} class="contact-link" target="_blank" rel="noopener">
            <div class="contact-link-icon" style="background:#222222;">
              <svg viewBox="0 0 24 24" style="fill:white;stroke:none;" width="18" height="18">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            WhatsApp — {site.whatsappDisplay}
          </a>

          <a href={"mailto:" + site.email} class="contact-link">
            <div class="contact-link-icon" style="background:var(--accent);">
              <svg viewBox="0 0 24 24">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/>
              </svg>
            </div>
            {site.email}
          </a>

          <a href={igHref} class="contact-link" target="_blank" rel="noopener">
            <div class="contact-link-icon" style="background:#333333;">
              <svg viewBox="0 0 24 24">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </div>
            @{site.instagram}
          </a>

        </div>
      </div>

      <!-- Formulário -->
      <div class="contact-form-wrap pop-in">
        <h3 style="font-size:1.3rem;font-weight:800;margin-bottom:1.5rem;">Envie uma mensagem</h3>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Nome</label>
            <input type="text" class="form-input" placeholder="Seu nome completo" />
          </div>
          <div class="form-group">
            <label class="form-label">E-mail</label>
            <input type="email" class="form-input" placeholder="seu@email.com" />
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Serviço de Interesse</label>
          <select class="form-input">
            <option value="">Selecione um serviço...</option>
            <option>Revisão Textual</option>
            <option>Diagramação</option>
            <option>Design de Capa</option>
            <option>ISBN e Registro</option>
            <option>Conversão para E-book</option>
            <option>Consultoria Editorial</option>
            <option>Pacote Completo</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Sobre seu projeto</label>
          <textarea class="form-input" placeholder="Conte-nos sobre seu livro: gênero, número de páginas, estágio atual..."></textarea>
        </div>
        <button
          class="btn-primary"
          style="width:100%;justify-content:center;font-size:16px;padding:14px 24px;"
          onclick="sendToWhatsApp()"
        >
          Enviar Mensagem
          <span class="btn-icon"><svg viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></span>
        </button>
        <p style="font-size:12px;color:var(--muted-fg);text-align:center;margin-top:12px;">
          Respondemos em até 24 horas úteis
        </p>
      </div>
    </div>
  </div>
</section>
