---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" aria-label="Filos Editora — página inicial">
          <img class="footer-logo" src="/images/logo-white.webp" alt="Filos Editora" width="100" height="36" loading="lazy" />
        </a>
        <p class="footer-tagline">Parceiros editoriais de autores que levam a escrita a sério. Do manuscrito ao livro publicado.</p>
      </div>

      <nav class="footer-nav" aria-label="Mapa do site">
        <a href="#servicos">Serviços</a>
        <a href="#sobre">Sobre</a>
        <a href="#depoimentos">Depoimentos</a>
        <a href="#faq">Perguntas frequentes</a>
        <a href="#contato">Contato</a>
      </nav>

      <div class="footer-contact">
        <a href="https://wa.me/5581999999999" target="_blank" rel="noopener">WhatsApp — (81) 99999-9999</a>
        <a href="mailto:contato@filoseditora.com.br">contato@filoseditora.com.br</a>
        <a href="https://instagram.com/filoseditora" target="_blank" rel="noopener">@filoseditora</a>
      </div>
    </div>

    <div class="footer-colophon">
      <p class="meta">© {year} Filos Editora. Todos os direitos reservados.</p>
      <p class="meta">Composto em Spectral &amp; Manrope, para autores brasileiros.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy);
    padding: var(--sp-6) 0 var(--sp-4);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr;
    gap: var(--sp-5);
    padding-bottom: var(--sp-5);
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }

  .footer-logo { height: 34px; width: auto; margin-bottom: var(--sp-3); filter: brightness(0) invert(1); }

  .footer-tagline {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.7;
    max-width: 30ch;
  }

  .footer-nav,
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .footer-nav a,
  .footer-contact a {
    font-family: var(--f-text);
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    width: max-content;
    transition: color var(--dur);
  }

  .footer-nav a:hover,
  .footer-contact a:hover { color: #fff; }

  .footer-colophon {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 21px;
    padding-top: var(--sp-3);
    flex-wrap: wrap;
  }

  .footer-colophon .meta { color: rgba(255,255,255,0.3); }

  @media (max-width: 760px) {
    .footer-top { grid-template-columns: 1fr; gap: var(--sp-4); }
    .footer-colophon { flex-direction: column; gap: 5px; }
  }
</style>
