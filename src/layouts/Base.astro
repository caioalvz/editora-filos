---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Filos Editora — Do Manuscrito ao Livro Publicado',
  description = 'Somos parceiros editoriais de autores que levam a escrita a sério. Cada projeto recebe atenção, cuidado e o suporte técnico que ele merece.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
  <!-- is:inline → Astro não processa/bundla; carregado diretamente do public/ -->
  <script src="/js/main.js" is:inline></script>
</body>
</html>
