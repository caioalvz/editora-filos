---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Filos Editora — Do Manuscrito ao Livro Publicado',
  description = 'Transformamos seu manuscrito em livro publicado globalmente. Design premium, ISBN, DOI, distribuição em +40 plataformas e lançamento editorial. Conheça a Filos.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://filoseditora.com.br/" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://filoseditora.com.br/" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:site_name" content="Filos Editora" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Fonts: Outfit (títulos) + Inter (texto) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;1,14..32,400;1,14..32,500&display=swap"
    rel="stylesheet"
  />

  <style is:global>
    /* ════════════════════════════════════════════════
       SISTEMA TONAL — um único matiz sépia-bronze,
       do quase-preto à luz de papel envelhecido.
    ════════════════════════════════════════════════ */
    :root {
      /* escala de tinta (escuro → claro) */
      --ink-9: #15110c;   /* fundo base — nunca #000 */
      --ink-8: #1b1610;
      --ink-7: #231d15;
      --ink-6: #32291d;
      --ink-5: #4a3e2c;   /* só decorativo, nunca texto pequeno */
      --ink-3: #97876f;   /* metadados, fólios */
      --ink-2: #c2b198;   /* texto secundário */
      --ink-1: #eae1d1;   /* texto principal */
      --ink-0: #f6f0e4;   /* realce máximo */

      /* o "acento" é um tom claro da mesma escala */
      --tone:  #d9bf90;
      --tone-deep: #b89a64;

      /* filetes */
      --line:        rgba(217,191,144,0.14);
      --line-strong: rgba(217,191,144,0.32);

      /* tipografia */
      --f-display: 'Outfit', sans-serif;
      --f-text:    'Inter', system-ui, sans-serif;

      /* ritmo: escala própria, não múltiplos de 8 */
      --sp-1: 0.4375rem;   /*  7px */
      --sp-2: 0.8125rem;   /* 13px */
      --sp-3: 1.3125rem;   /* 21px */
      --sp-4: 2.125rem;    /* 34px */
      --sp-5: 3.4375rem;   /* 55px */
      --sp-6: 5.5625rem;   /* 89px */

      --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
      --dur: 0.3s;

      --max-w: 1180px;
    }

    /* ════════ RESET ════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; font-size: 16px; }

    body {
      font-family: var(--f-text);
      background: var(--ink-9);
      color: var(--ink-1);
      line-height: 1.75;
      font-size: 1rem;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    a { text-decoration: none; color: inherit; }
    ul { list-style: none; }
    img { display: block; max-width: 100%; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; color: inherit; }

    ::selection { background: var(--tone); color: var(--ink-9); }

    /* ════════ TIPOGRAFIA ════════ */
    h1, h2, h3, h4 { font-family: var(--f-display); text-wrap: balance; }

    h1 {
      font-size: clamp(2.7rem, 6.4vw, 5.4rem);
      font-weight: 600;
      line-height: 0.98;
      letter-spacing: -0.028em;
      color: var(--ink-0);
    }

    h2 {
      font-size: clamp(1.9rem, 4vw, 3.1rem);
      font-weight: 500;
      line-height: 1.04;
      letter-spacing: -0.022em;
      color: var(--ink-0);
    }

    h3 {
      font-size: 1.35rem;
      font-weight: 500;
      letter-spacing: -0.012em;
      color: var(--ink-0);
    }

    p { max-width: 68ch; text-wrap: pretty; }

    .prose {
      font-size: 1.0625rem;
      color: var(--ink-2);
      line-height: 1.82;
    }

    .meta {
      font-family: var(--f-text);
      font-size: 0.8125rem;
      font-style: italic;
      color: var(--ink-3);
      letter-spacing: 0.01em;
    }

    /* ════════ LAYOUT ════════ */
    .container {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 clamp(22px, 5vw, 64px);
    }

    /* filete editorial reutilizável */
    .rule { height: 1px; background: var(--line); border: none; }

    /* ════════ AÇÕES ════════ */
    .btn-fill {
      display: inline-flex;
      align-items: center;
      gap: 11px;
      background: var(--tone);
      color: var(--ink-9);
      font-family: var(--f-display);
      font-weight: 600;
      font-size: 0.9375rem;
      letter-spacing: 0.01em;
      padding: 17px 34px;
      border-radius: 2px;
      transition: background var(--dur) var(--ease-out), transform var(--dur) var(--ease-out);
      white-space: nowrap;
    }

    .btn-fill:hover { background: var(--ink-0); transform: translateY(-1px); }

    .btn-fill svg {
      width: 17px; height: 17px;
      fill: none; stroke: currentColor; stroke-width: 2.2;
      stroke-linecap: round; stroke-linejoin: round;
      flex-shrink: 0;
    }

    .link-line {
      display: inline-flex;
      align-items: baseline;
      gap: 7px;
      font-family: var(--f-display);
      font-weight: 500;
      font-size: 0.9375rem;
      color: var(--ink-1);
      border-bottom: 1px solid var(--line-strong);
      padding-bottom: 3px;
      transition: color var(--dur), border-color var(--dur);
    }

    .link-line:hover { color: var(--tone); border-color: var(--tone); }

    /* ════════ REVELAÇÃO (gated por JS: sem JS, tudo visível) ════════ */
    html.js .reveal {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out);
    }

    html.js .reveal.in { opacity: 1; transform: none; }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
      html.js .reveal { opacity: 1; transform: none; }
      html { scroll-behavior: auto; }
    }

    /* ════════ FOCO ════════ */
    :focus-visible {
      outline: 2px solid var(--tone);
      outline-offset: 3px;
    }
  </style>
</head>
<body>
  <slot />

  <script>
    document.documentElement.classList.add('js');

    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }),
      { threshold: 0.12, rootMargin: '0px 0px -30px 0px' }
    );
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  </script>
<!-- impeccable-live-start -->
<script is:inline src="http://localhost:8400/live.js"></script>
<!-- impeccable-live-end -->
</body>
</html>
