---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Filos Editora — Do Manuscrito ao Livro Publicado',
  description = 'Transformamos seu manuscrito em livro publicado globalmente. Design premium, ISBN, DOI, distribuição em +40 plataformas e lançamento editorial. Conheça a Filos.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://filoseditora.com.br/" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://filoseditora.com.br/" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:site_name" content="Filos Editora" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Lora:ital,wght@0,400;0,500;1,400&display=swap"
    rel="stylesheet"
  />

  <style is:global>
    /* ══════════════════════════════════════════
       DESIGN TOKENS
    ══════════════════════════════════════════ */
    :root {
      --bg:      #1b1814;
      --bg2:     #221f1b;
      --bg3:     #2b2722;
      --bg4:     #333028;

      --text:    #f2ede6;
      --text2:   #a09080;
      --text3:   #635850;

      --gold:    #c8a96e;
      --gold-bg: rgba(200,169,110,0.12);
      --gold-bd: rgba(200,169,110,0.26);

      --border:  rgba(255,255,255,0.07);
      --border2: rgba(255,255,255,0.13);

      --sh-sm: 0 2px 12px rgba(0,0,0,.4);
      --sh-md: 0 8px 32px rgba(0,0,0,.5);
      --sh-lg: 0 20px 64px rgba(0,0,0,.6);

      --p1: #7aaee8;
      --p1b: rgba(122,174,232,0.12);
      --p1e: rgba(122,174,232,0.28);

      --p2: #6ecfb5;
      --p2b: rgba(110,207,181,0.12);
      --p2e: rgba(110,207,181,0.28);

      --p3: #d4b85a;
      --p3b: rgba(212,184,90,0.12);
      --p3e: rgba(212,184,90,0.28);

      --p4: #b48ae0;
      --p4b: rgba(180,138,224,0.12);
      --p4e: rgba(180,138,224,0.28);

      --f-titles: 'Outfit', sans-serif;
      --f-body:   'Lora', Georgia, serif;

      --r-pill: 999px;
      --r-xl:   24px;
      --r-lg:   16px;
      --r-md:   12px;
      --r-sm:   8px;

      --ease: cubic-bezier(0.4,0,0.2,1);
      --dur:  0.25s;

      --max-w: 1200px;
    }

    [data-theme="light"] {
      --bg:      #f0ebe2;
      --bg2:     #f8f4ee;
      --bg3:     #fffdf9;
      --bg4:     #ffffff;
      --text:    #1a1410;
      --text2:   #5a5040;
      --text3:   #9a8878;
      --gold:    #9a6f2e;
      --gold-bg: rgba(154,111,46,0.10);
      --gold-bd: rgba(154,111,46,0.26);
      --border:  rgba(60,40,20,0.08);
      --border2: rgba(60,40,20,0.15);
      --sh-sm: 0 2px 12px rgba(60,40,20,.10);
      --sh-md: 0 8px 32px rgba(60,40,20,.14);
      --sh-lg: 0 20px 64px rgba(60,40,20,.20);
      --p1: #1d6fb8;
      --p1b: rgba(29,111,184,0.08);
      --p1e: rgba(29,111,184,0.22);
      --p2: #187858;
      --p2b: rgba(24,120,88,0.08);
      --p2e: rgba(24,120,88,0.22);
      --p3: #9a7010;
      --p3b: rgba(154,112,16,0.08);
      --p3e: rgba(154,112,16,0.22);
      --p4: #7030b0;
      --p4b: rgba(112,48,176,0.08);
      --p4e: rgba(112,48,176,0.22);
    }

    /* ══════════════════════════════════════════
       RESET & BASE
    ══════════════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      scroll-behavior: smooth;
      font-size: 16px;
    }

    body {
      font-family: var(--f-body);
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
      transition: background .35s var(--ease), color .35s var(--ease);
    }

    a { text-decoration: none; color: inherit; }
    ul { list-style: none; }
    img { display: block; max-width: 100%; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; }

    /* ══════════════════════════════════════════
       TYPOGRAPHY
    ══════════════════════════════════════════ */
    h1, h2, h3, h4 { font-family: var(--f-titles); }

    h1 {
      font-size: clamp(2.8rem, 7vw, 5.5rem);
      font-weight: 800;
      line-height: 1.0;
      letter-spacing: -0.01em;
      color: var(--text);
    }

    h2 {
      font-size: clamp(2rem, 4.5vw, 3.4rem);
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -0.01em;
      color: var(--text);
    }

    h3 {
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--text);
    }

    p { font-family: var(--f-body); }

    .highlight { color: var(--gold); }

    .section-eyebrow {
      display: inline-block;
      font-family: var(--f-titles);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      background: var(--gold-bg);
      border: 1px solid var(--gold-bd);
      padding: 5px 14px;
      border-radius: var(--r-pill);
      margin-bottom: 1rem;
    }

    .section-sub {
      font-family: var(--f-body);
      color: var(--text2);
      font-size: 1.05rem;
      max-width: 560px;
      line-height: 1.8;
    }

    /* ══════════════════════════════════════════
       LAYOUT
    ══════════════════════════════════════════ */
    .container {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 28px;
    }

    section { padding: 96px 0; position: relative; }

    /* ══════════════════════════════════════════
       BUTTONS
    ══════════════════════════════════════════ */
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--gold);
      color: #1a1208;
      font-family: var(--f-titles);
      font-weight: 700;
      font-size: 0.9rem;
      letter-spacing: 0.03em;
      padding: 14px 28px;
      border-radius: var(--r-pill);
      box-shadow: 0 6px 24px rgba(200,169,110,.30);
      transition: all var(--dur) var(--ease);
      white-space: nowrap;
      min-height: 48px;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 32px rgba(200,169,110,.45);
      filter: brightness(1.07);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--bg3);
      color: var(--text);
      font-family: var(--f-titles);
      font-weight: 600;
      font-size: 0.9rem;
      padding: 13px 26px;
      border-radius: var(--r-pill);
      border: 1px solid var(--border2);
      box-shadow: var(--sh-sm);
      transition: all var(--dur) var(--ease);
      white-space: nowrap;
      min-height: 48px;
    }

    .btn-secondary:hover {
      background: var(--bg4);
      transform: translateY(-1px);
      box-shadow: var(--sh-md);
    }

    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: transparent;
      color: var(--text);
      font-family: var(--f-titles);
      font-weight: 600;
      font-size: 0.9rem;
      padding: 13px 26px;
      border-radius: var(--r-pill);
      border: 1px solid var(--border2);
      transition: all var(--dur) var(--ease);
      white-space: nowrap;
      min-height: 48px;
    }

    .btn-ghost:hover { background: var(--bg3); }

    .btn-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      flex-shrink: 0;
    }

    .btn-icon svg {
      width: 100%;
      height: 100%;
      fill: none;
      stroke: currentColor;
      stroke-width: 2.5;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    /* ══════════════════════════════════════════
       ANIMATIONS
    ══════════════════════════════════════════ */
    .animate-on-scroll {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.55s var(--ease), transform 0.55s var(--ease);
    }

    .animate-on-scroll.visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
      .animate-on-scroll {
        opacity: 1;
        transform: none;
      }
      html { scroll-behavior: auto; }
    }

    /* ══════════════════════════════════════════
       FOCUS
    ══════════════════════════════════════════ */
    :focus-visible {
      outline: 2px solid var(--gold);
      outline-offset: 3px;
      border-radius: 4px;
    }

    /* ══════════════════════════════════════════
       RESPONSIVE UTILS
    ══════════════════════════════════════════ */
    @media (max-width: 768px) {
      section { padding: 64px 0; }
      .container { padding: 0 20px; }
    }

    @media (max-width: 480px) {
      section { padding: 48px 0; }
    }
  </style>
</head>
<body>
  <slot />

  <script>
    // ── Theme ──
    const html = document.documentElement;
    const saved = localStorage.getItem('filos-theme');
    if (saved) {
      html.setAttribute('data-theme', saved);
    } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
      html.setAttribute('data-theme', 'light');
    }

    // ── Scroll animation ──
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.08, rootMargin: '0px 0px -20px 0px' }
    );
    document.querySelectorAll('.animate-on-scroll').forEach(el => io.observe(el));

    // ── Header scroll ──
    const header = document.getElementById('site-header');
    if (header) {
      window.addEventListener('scroll', () => {
        header.classList.toggle('scrolled', window.scrollY > 50);
      }, { passive: true });
    }
  </script>
</body>
</html>
