---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Filos Editora — Do Manuscrito ao Livro Publicado',
  description = 'Transformamos seu manuscrito em livro publicado globalmente. Design premium, ISBN, DOI, distribuição em +40 plataformas e lançamento editorial. Conheça a Filos.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://filoseditora.com.br/" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://filoseditora.com.br/" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:site_name" content="Filos Editora" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Fonts: Spectral (títulos) + Manrope (UI e corpo) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Manrope:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <style is:global>
    /* ════════════════════════════════════════════════
       SISTEMA TONAL — branco, preto e tons de cinza.
    ════════════════════════════════════════════════ */
    :root {
      /* escala de tinta (claro → escuro) */
      --ink-9: #ffffff;   /* fundo base */
      --ink-8: #f6f5f3;
      --ink-7: #ecebe8;
      --ink-6: #d8d6d2;
      --ink-5: #b4b1ac;   /* só decorativo, nunca texto pequeno */
      --ink-3: #6c6964;   /* metadados, fólios */
      --ink-2: #45423e;   /* texto secundário */
      --ink-1: #1d1b19;   /* texto principal */
      --ink-0: #0e0d0c;   /* realce máximo */

      /* acentos na mesma escala */
      --tone:  #161513;        /* preenchimento de botões */
      --tone-deep: #6c6964;    /* realce tipográfico em cinza */

      /* paleta cromática — derivada do brand do criador */
      --navy:        #0d344c;  /* azul-naval escuro — seções escuras */
      --navy-light:  #145c7a;  /* navy mais claro — hover */
      --teal:        #1a7a6e;  /* esmeralda editorial — acento premium */
      --amber:       #c9901e;  /* âmbar quente — CTA e destaques */
      --amber-mute:  #f5e9d0;  /* âmbar claro — fundos sutis */
      --terra:       #b54632;  /* terracota — depoimentos */

      /* filetes */
      --line:        rgba(20,19,17,0.12);
      --line-strong: rgba(20,19,17,0.30);

      /* tipografia */
      --f-head:    'Spectral', Georgia, serif;    /* títulos editoriais */
      --f-display: 'Manrope', sans-serif;         /* UI: botões, labels, nav */
      --f-text:    'Manrope', system-ui, sans-serif;

      /* ritmo: escala própria, não múltiplos de 8 */
      --sp-1: 0.4375rem;   /*  7px */
      --sp-2: 0.8125rem;   /* 13px */
      --sp-3: 1.3125rem;   /* 21px */
      --sp-4: 2.125rem;    /* 34px */
      --sp-5: 3.4375rem;   /* 55px */
      --sp-6: 5.5625rem;   /* 89px */

      --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
      --dur: 0.3s;

      --max-w: 1180px;
    }

    /* ════════ RESET ════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; font-size: 16px; }

    body {
      font-family: var(--f-text);
      background: var(--ink-9);
      color: var(--ink-1);
      line-height: 1.75;
      font-size: 1rem;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    a { text-decoration: none; color: inherit; }
    ul { list-style: none; }
    img { display: block; max-width: 100%; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; color: inherit; }

    ::selection { background: var(--tone); color: var(--ink-9); }

    /* ════════ TIPOGRAFIA ════════ */
    h1, h2, h3, h4 {
      font-family: var(--f-head);
      text-wrap: balance;
    }

    h1 {
      font-size: clamp(2.6rem, 5.8vw, 5.2rem);
      font-weight: 300;
      line-height: 1.02;
      letter-spacing: -0.018em;
      color: var(--ink-0);
    }

    h2 {
      font-size: clamp(1.85rem, 3.8vw, 3rem);
      font-weight: 400;
      line-height: 1.1;
      letter-spacing: -0.012em;
      color: var(--ink-0);
    }

    h3 {
      font-size: 1.3rem;
      font-weight: 500;
      letter-spacing: -0.006em;
      color: var(--ink-0);
    }

    p { max-width: 68ch; text-wrap: pretty; }

    .prose {
      font-size: 1.0625rem;
      color: var(--ink-2);
      line-height: 1.82;
    }

    .meta {
      font-family: var(--f-text);
      font-size: 0.8125rem;
      font-style: italic;
      color: var(--ink-3);
      letter-spacing: 0.01em;
    }

    /* ════════ LAYOUT ════════ */
    .container {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 clamp(22px, 5vw, 64px);
    }

    /* filete editorial reutilizável */
    .rule { height: 1px; background: var(--line); border: none; }

    /* ════════ AÇÕES ════════ */
    .btn-fill {
      display: inline-flex;
      align-items: center;
      gap: 11px;
      background: var(--tone);
      color: var(--ink-9);
      font-family: var(--f-display);
      font-weight: 600;
      font-size: 0.9375rem;
      letter-spacing: 0.01em;
      padding: 17px 34px;
      border-radius: 2px;
      transition: background var(--dur) var(--ease-out), transform var(--dur) var(--ease-out);
      white-space: nowrap;
    }

    .btn-fill:hover { background: var(--ink-0); transform: translateY(-1px); }

    .btn-fill svg {
      width: 17px; height: 17px;
      fill: none; stroke: currentColor; stroke-width: 2.2;
      stroke-linecap: round; stroke-linejoin: round;
      flex-shrink: 0;
    }

    .link-line {
      display: inline-flex;
      align-items: baseline;
      gap: 7px;
      font-family: var(--f-display);
      font-weight: 500;
      font-size: 0.9375rem;
      color: var(--ink-1);
      border-bottom: 1px solid var(--line-strong);
      padding-bottom: 3px;
      transition: color var(--dur), border-color var(--dur);
    }

    .link-line:hover { color: var(--tone); border-color: var(--tone); }

    /* ════════ REVELAÇÃO (gated por JS: sem JS, tudo visível) ════════ */
    html.js .reveal {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out);
    }

    html.js .reveal.in { opacity: 1; transform: none; }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
      html.js .reveal { opacity: 1; transform: none; }
      html { scroll-behavior: auto; }
    }

    /* ════════ FOCO ════════ */
    :focus-visible {
      outline: 2px solid var(--tone);
      outline-offset: 3px;
    }
  </style>
</head>
<body>
  <slot />

  <script>
    document.documentElement.classList.add('js');

    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }),
      { threshold: 0.12, rootMargin: '0px 0px -30px 0px' }
    );
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  </script>
</body>
</html>
